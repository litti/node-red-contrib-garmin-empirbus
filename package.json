{
  "name": "node-red-contrib-garmin-empirbus",
  "license": "MIT",
  "version": "1.1.31",
  "description": "Connects to Garmin Empirbus MCU or Serv7 Display to enable status and switching",
  "keywords": [
    "node-red"
  ],
  "bugs": {
    "url": "https://github.com/litti/node-red-contrib-garmin-empirbus/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "empirbus-config": "dist/nodes/empirbus-config.js",
      "empirbus-dim": "dist/nodes/empirbus-dim.js",
      "empirbus-state": "dist/nodes/empirbus-state.js",
      "empirbus-switch": "dist/nodes/empirbus-switch.js",
      "empirbus-toggle": "dist/nodes/empirbus-toggle.js"
    }
  },
  "scripts": {
    "build": "tsc && yarn copy:examples && yarn copy:html && yarn build:resources",
    "build:resources": "tsc -p tsconfig.resources.json",
    "copy:examples": "copyfiles -u 1 \"examples/**/*.*\" dist",
    "copy:html": "copyfiles -u 1 \"src/nodes/**/*.html\" dist",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "garmin-empirbus-ts": "^0.1.23"
  },
  "devDependencies": {
    "@types/node": "20",
    "@types/node-red": "^1.3.5",
    "@types/node-red__editor-api": "^1.3.5",
    "copyfiles": "^2.4.1",
    "dotenv-cli": "^11.0.0",
    "typescript": "^5.9.3"
  }
}
